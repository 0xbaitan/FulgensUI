{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "panda": {
      "cache": true,
      "outputs": ["src/styled-system/**"]
    },
    "type-check": {
      "dependsOn": ["panda"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build", "panda"],
      "outputs": ["dist/**", "build/**", "storybook-static/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["panda"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["panda"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "clear": {
      "cache": false
    }
  }
}
