{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "react-jsx",

    "paths": {
      "@/*": ["./src/*"],
      "@site/*": ["./"]
    }
  },
  "include": ["src", "docusaurus.config.ts", "sidebars.ts"],
  "exclude": ["node_modules"]
}
