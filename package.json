{
  "name": "fulgensui",
  "version": "0.0.1",
  "private": true,
  "description": "A UI Component Library made with React and PandaCSS for reusability in frontend projects",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "clear": "rm -rf node_modules/.cache/ .turbo package-lock.json && turbo run clear",
    "prepare": "husky",
    "ai-commit": "bun scripts/ai-commit-agent.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@pandacss/dev": "^1.8.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^10.2.0",
    "@storybook/react-vite": "^10.2.0",
    "add": "^2.0.6",
    "autoprefixer": "^10.4.23",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "storybook": "^10.2.0",
    "turbo": "^2.3.3",
    "vite-tsconfig-paths": "^6.0.5"
  },
  "packageManager": "bun@1.3.0",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@docusaurus/plugin-content-docs": "^3.9.2"
  }
}
